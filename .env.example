# Environment Variables for Hybrid AI-Quantum Satellite Image Encryption System
#
# SECURITY WARNING:
# This file (.env.example) is SAFE to commit to git (shows structure only)
# Your actual .env file (local copy) must be added to .gitignore and NEVER committed
#
# HOW TO USE:
# 1. Copy this file: cp .env.example .env  (or copy .env.example .env on Windows)
# 2. Edit .env with your actual values
# 3. Run: python main.py (automatically loads from .env)
#
# ============================================================================
# CRITICAL: Set a strong passphrase for key protection
# This protects your encryption keys at rest using Scrypt + AES-256-GCM
# ============================================================================
ENCRYPTION_PASSPHRASE=your-strong-passphrase-here

# ============================================================================
# Post-Quantum Cryptography Keys (Kyber768 - ML-KEM)
# Required for encryption/decryption if post_quantum.enabled = true
# ============================================================================
RECIPIENT_PRIVATE_KEY_PATH=keys/recipient_kyber768_private.key

# ============================================================================
# Digital Signature Keys (Dilithium3 - ML-DSA)
# Required for metadata signing if metadata_signature.enabled = true
# ============================================================================
SENDER_PRIVATE_KEY_PATH=keys/sender_dilithium3_private.key
