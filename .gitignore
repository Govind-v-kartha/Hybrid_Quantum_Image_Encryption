# ============================================================================
# SECURITY: Sensitive Files (NEVER COMMIT)
# ============================================================================

# Configuration with secrets (use config.example.json as template)
config/config.json              # Instance config (has passphrases, key paths)
.env                            # Environment variables
.env.local                       # Local overrides
.env.*.local                     # Environment-specific

# Cryptographic keys (CRITICAL - never expose)
keys/                           # All private/public keys
*.key                           # Any key file
*.pem                           # PEM format keys
*.enc                           # Encrypted files (keys, backups)

# Encrypted data (generated at runtime)
output/                         # All encrypted images, metadata
*.enc

# Model weights (large, regenerate as needed)
DOFA_ViT_base_e100.pth

# Logs (may contain sensitive info)
logs/
*.log
full_run.log

# ============================================================================
# Python
# ============================================================================

__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
.venv/
venv/
env/

# ============================================================================
# IDE & Development
# ============================================================================

.vscode/
.idea/
*.swp
*.swo
*~

# Jupyter
.ipynb_checkpoints/

